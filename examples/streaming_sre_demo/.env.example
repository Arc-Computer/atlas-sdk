# Streaming SRE demo environment overrides

# Required: OpenAI credential with access to gpt-5
OPENAI_API_KEY=sk-demo

# Postgres DSN used by the demo runtime (defaults to docker-compose stack)
ATLAS_SRE_DEMO_DATABASE_URL=postgresql://atlas:atlas@localhost:5433/atlas_arc_demo

# Optional overrides for the BYOA Python adapter
SRE_AGENT_MODEL=gpt-5
SRE_AGENT_TEMPERATURE=1.0
